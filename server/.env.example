# pipecat-esp32-smallwebrtc-demo - Environment Variables
# Copy this file to .env and fill in your API keys

# Deepgram (STT + TTS)
DEEPGRAM_API_KEY=
DEEPGRAM_STT_MODEL=flux-general-en
DEEPGRAM_TTS_VOICE=aura-2-helena-en
DEEPGRAM_TTS_SAMPLE_RATE=16000
DEEPGRAM_TTS_ENCODING=linear16

# Anthropic Claude (LLM)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Next.js backend URL (internal, for tool API calls from this server)
NEXTJS_URL=http://localhost:3000

# Public URL where the Next.js app is reachable by customers' phones
# (used in QR codes). Falls back to NEXTJS_URL if not set.
# Should match NEXT_PUBLIC_URL in the Next.js .env.
# NEXT_PUBLIC_URL=https://your-kiosk.example.com

# Optional: public base URL for the Pipecat server itself (used only when
# generating local fallback maps if Next.js is unavailable). If omitted,
# the Pipecat runner host/port are used.
# KIOSK_PUBLIC_BASE_URL=http://192.168.1.10:7860
